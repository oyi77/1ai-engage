[Unit]
Description=1ai-engage Next.js Dashboard
After=network.target 1ai-engage-mcp.service

[Service]
Type=simple
User=openclaw
WorkingDirectory=/home/openclaw/.openclaw/workspace/1ai-engage/dashboard
Environment="PATH=/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/Cellar/node@24/24.14.1/bin:/usr/local/bin:/usr/bin:/bin"
Environment="NODE_ENV=production"
ExecStart=/home/linuxbrew/.linuxbrew/Cellar/node@24/24.14.1/bin/node /home/openclaw/.openclaw/workspace/1ai-engage/dashboard/node_modules/.bin/next start -p 8502
Restart=always
RestartSec=10
StandardOutput=append:/home/openclaw/.openclaw/workspace/1ai-engage/logs/dashboard.log
StandardError=append:/home/openclaw/.openclaw/workspace/1ai-engage/logs/dashboard.log

[Install]
WantedBy=multi-user.target
