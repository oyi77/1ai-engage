[Unit]
Description=1ai-reach Webhook Server
After=network.target

[Service]
Type=simple
User=openclaw
WorkingDirectory=/home/openclaw/projects/1ai-reach
ExecStart=/usr/bin/python3 /home/openclaw/projects/1ai-reach/webhook_server.py
Restart=always
RestartSec=10
StandardOutput=append:/home/openclaw/projects/1ai-reach/logs/webhook.log
StandardError=append:/home/openclaw/projects/1ai-reach/logs/webhook.log

[Install]
WantedBy=multi-user.target
